---
/**
 * Footer Component
 * Encapsulates the footer layout and global links, maintaining DRY principles
 * by keeping the page shells focused only on their unique contents.
 */
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const withBase = (path: string) => {
  if (path.startsWith('#')) return `${base}${path}`;
  return `${base}${path.replace(/^\/+/, '')}`;
};
---

<footer class="border-t border-gold-pale/70 bg-white/80">
  <div class="mx-auto flex max-w-7xl flex-col gap-4 px-5 py-8 text-sm text-slate-500 md:flex-row md:items-center md:justify-between md:px-8">
    <p>&copy; {new Date().getFullYear()} NESHISE. Accessible AI for all.</p>
    <div class="flex gap-5">
      <a class="transition hover:text-gold-deep" href={withBase('blog')}>Blog</a>
      <a class="transition hover:text-gold-deep" href={withBase('youtube')}>YouTube</a>
      <a class="transition hover:text-gold-deep" href={withBase('resources')}>Resources</a>
      <a class="transition hover:text-gold-deep" href={withBase('#contact')}>Contact</a>
    </div>
  </div>
</footer>
