---
/**
 * Contact Section Component
 * Abstracts the bottom call-to-action module.
 */
---

<section id="contact" class="py-24">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="rounded-[2rem] border border-gold-pale bg-ink p-8 text-white shadow-soft md:p-12">
      <p class="mb-4 text-sm font-black uppercase tracking-[0.24em] text-gold-light">Start with NESHISE</p>
      <h2 class="max-w-3xl text-4xl font-black tracking-tight md:text-5xl">Turn AI into a brand, content engine, and useful online ecosystem.</h2>
      <a href="mailto:hello@neshi.dev" class="mt-8 inline-flex rounded-full bg-white px-7 py-4 text-sm font-black uppercase tracking-[0.16em] text-ink transition hover:-translate-y-0.5 hover:bg-gold-pale">
        hello@neshi.dev
      </a>
    </div>
  </div>
</section>
