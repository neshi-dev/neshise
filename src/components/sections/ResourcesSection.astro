---
/**
 * Resources Section Component
 * Renders the hub cards using the central data constants to adhere to the DRY principle.
 */
import { HUB_RESOURCES } from '../../lib/constants';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
---

<section class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="mb-10 flex flex-col justify-between gap-6 md:flex-row md:items-end">
      <div>
        <p class="mb-4 text-sm font-black uppercase tracking-[0.24em] text-gold">Resource Hub</p>
        <h2 class="max-w-3xl text-4xl font-black tracking-tight md:text-5xl">A library for building with AI.</h2>
      </div>
      <a href={withBase('resources')} class="text-sm font-black uppercase tracking-[0.18em] text-gold-deep underline decoration-gold-light underline-offset-8">Open hub</a>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      {HUB_RESOURCES.map((resource) => (
        <div class="holo-border rounded-[1.4rem] bg-white p-[1px] shadow-soft">
          <div class="h-full rounded-[1.35rem] border border-slate-100 bg-white p-7">
            <p class="text-xl font-black tracking-tight text-ink">{resource.title}</p>
            <p class="mt-4 leading-7 text-slate-600">{resource.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
