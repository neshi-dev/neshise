---
/**
 * Services Section Component
 * Dynamically iterates over the SERVICE_PILLARS to render feature cards,
 * keeping the component logic DRY.
 */
import FeatureCard from '../FeatureCard.astro';
import { SERVICE_PILLARS } from '../../lib/constants';
---

<section id="services" class="py-24">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="mb-10 flex flex-col justify-between gap-5 md:flex-row md:items-end">
      <div>
        <p class="mb-4 text-sm font-black uppercase tracking-[0.24em] text-gold">Services</p>
        <h2 class="max-w-4xl text-4xl font-black tracking-tight md:text-5xl">Build visibility, trust, and useful AI systems around your brand.</h2>
      </div>
    </div>
    <div class="grid gap-6 md:grid-cols-2">
      {SERVICE_PILLARS.map((pillar) => (
        <FeatureCard eyebrow={pillar.label} title={pillar.title} description={pillar.text} />
      ))}
    </div>
  </div>
</section>
