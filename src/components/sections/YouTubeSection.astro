---
/**
 * YouTube Section Component
 * Abstracts the YouTube channel promotion block.
 */
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
---

<section class="bg-ink py-24 text-white">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 md:px-8 lg:grid-cols-[1fr_1fr] lg:items-center">
    <div>
      <p class="mb-4 text-sm font-black uppercase tracking-[0.24em] text-gold-light">YouTube channel</p>
      <h2 class="text-4xl font-black tracking-tight md:text-5xl">Short, useful AI tutorials with a calm signal.</h2>
      <p class="mt-5 text-lg leading-8 text-slate-300">
        The channel is shaped for clear step-by-step videos on AI tools, online business workflows, faceless content systems, and practical automation.
      </p>
      <a href={withBase('youtube')} class="mt-8 inline-flex rounded-full bg-white px-7 py-4 text-sm font-black uppercase tracking-[0.16em] text-ink transition hover:-translate-y-0.5 hover:bg-gold-pale">
        Visit Channel Plan
      </a>
    </div>
    <div class="holo-border rounded-[1.5rem] bg-white/5 p-[1px]">
      <div class="rounded-[1.45rem] border border-white/10 bg-white/5 p-6">
        <div class="aspect-video rounded-2xl border border-gold-light/30 bg-gradient-to-br from-white/12 via-hologram-blue/20 to-hologram-violet/20"></div>
        <div class="mt-5 grid gap-3 sm:grid-cols-3">
          <p class="rounded-xl border border-white/10 p-4 text-sm text-slate-300">AI tutorials</p>
          <p class="rounded-xl border border-white/10 p-4 text-sm text-slate-300">SEO workflows</p>
          <p class="rounded-xl border border-white/10 p-4 text-sm text-slate-300">Creator systems</p>
        </div>
      </div>
    </div>
  </div>
</section>
